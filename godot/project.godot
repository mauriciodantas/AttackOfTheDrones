; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes in []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Attack of the Drones"
config/description="Tower defense shooting game - migrated from Cocos2d/Swift to Godot 4"
run/main_scene="res://scenes/LoadingScene.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://assets/images/logo.png"

[audio]

buses/default_bus_layout=""

[display]

window/size/viewport_width=375
window/size/viewport_height=667
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[input]

tap={
"deadzone": 0.5,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":1,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":true,"double_click":false,"script":null)
, Object(InputEventScreenTouch,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"index":0,"position":Vector2(0, 0),"radius":0.0,"pressed":true,"canceled":false,"double_click":false,"script":null)
]
}

[physics]

2d/gravity=985.0

[autoload]

GameState="*res://scripts/GameState.gd"
SoundManager="*res://scenes/SoundManager.tscn"

[rendering]

renderer/rendering_method="mobile"
textures/canvas_textures/default_texture_filter=0
